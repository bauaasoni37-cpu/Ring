{
  "cli": {
    "version": ">= 18.12.1",

    "appVersionSource": "remote"
  },

  "build": {
    "development": {
      "developmentClient": true,

      "distribution": "internal",

      "env": {
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    },

    "preview": {
      "distribution": "internal",

      "android": {
        "buildType": "apk"
      },

      "env": {
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    },

    "production": {
      "autoIncrement": true,

      "android": {
        "buildType": "app-bundle"
      },

      "env": {
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    }
  },

  "submit": {
    "production": {}
  }
}